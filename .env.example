APP_ENV=development
DATABASE_URL=postgresql+asyncpg://ai_course:ai_course@localhost:5432/ai_course
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND_URL=redis://localhost:6379/1
LOG_LEVEL=INFO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=ai-course
INGESTION_MAX_FILE_SIZE_BYTES=26214400
INGESTION_CHUNK_TARGET_TOKENS=300
INGESTION_CHUNK_MAX_TOKENS=400
INGESTION_EMBEDDING_BATCH_SIZE=32
SEARXNG_URL=http://localhost:8080
LLM_PROVIDER=
LLM_API_KEY=

# Phase 4 public-web discovery (browser remains off by default)
SEARXNG_URL=http://localhost:8080
SEARCH_TIMEOUT_SECONDS=5
FETCH_MAX_BYTES=2000000
FETCH_REDIRECT_LIMIT=5
BROWSER_PROVIDER_ENABLED=false
ROBOTS_USER_AGENT=ai-course-research-bot/0.1

# Phase 5 research orchestration
RESEARCH_WORKFLOW_VERSION=phase5.v1
RESEARCH_QUERY_BUDGET=20
RESEARCH_SOURCE_BUDGET=20
RESEARCH_MODEL_CALL_BUDGET=20
RESEARCH_MAX_FOLLOWUP_ROUNDS=2
RESEARCH_MIN_INFORMATION_GAIN=0.15
